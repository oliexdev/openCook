<!--
  Adaptive-Icon Foreground layer.
  Lucide `utensils` glyph (ISC). Scaled to ~58dp (scale 2.4) and centered on the
  glyph's bounds (center 12,11 in the 24-grid → canvas center 54,54) so the circular
  launcher mask doesn't clip it; stroke 2 × scale 2.4 ≈ 4.8dp visual.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="25.2"
        android:translateY="27.6"
        android:scaleX="2.4"
        android:scaleY="2.4">

        <path
            android:strokeColor="#FBF5EE"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M3,2 v7 c0,1.1 0.9,2 2,2 h4 a2,2 0 0 0 2,-2 V2" />
        <path
            android:strokeColor="#FBF5EE"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M7,2 v20" />
        <path
            android:strokeColor="#FBF5EE"
            android:strokeWidth="2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M21,15 V2 V0 a5,5 0 0 0 -5,5 v6 c0,1.1 0.9,2 2,2 h3 Z m0,0 v7" />
    </group>
</vector>
